{
  "version": 1,
  "expectedToolCount": 24,
  "cases": [
    {
      "id": "console-errors",
      "category": "observability",
      "prompt": "Show me only error and warning console messages from the current page load.",
      "expectedTool": "list_console_messages",
      "expectedArgs": {"types": ["error", "warn"]}
    },
    {
      "id": "list-script-urls",
      "category": "scripts",
      "prompt": "List loaded JavaScript whose URL contains analytics; I do not want to search source text yet.",
      "expectedTool": "list_scripts",
      "expectedArgs": {"filter": "analytics"}
    },
    {
      "id": "read-source-region",
      "category": "scripts",
      "prompt": "Read lines 120 through 150 from the loaded script https://example.com/static/app.js.",
      "expectedTool": "get_script_source",
      "expectedArgs": {
        "url": "https://example.com/static/app.js",
        "startLine": 120,
        "endLine": 150
      }
    },
    {
      "id": "save-minified-source",
      "category": "scripts",
      "prompt": "Save the complete loaded bundle https://example.com/static/app.min.js to /tmp/app-readable.js and format it. The destination is new.",
      "expectedTool": "save_script_source",
      "expectedArgs": {
        "url": "https://example.com/static/app.min.js",
        "filePath": "/tmp/app-readable.js"
      }
    },
    {
      "id": "search-compressed-sources",
      "category": "scripts",
      "prompt": "在全部已加载的 JavaScript 中查找字面量 encryptPayload，包括 inline、eval 和压缩 bundle。",
      "expectedTool": "search_in_sources",
      "expectedArgs": {"query": "encryptPayload"}
    },
    {
      "id": "remove-xhr-breakpoint",
      "category": "destructive_actions",
      "prompt": "Remove the XHR breakpoint whose URL pattern is /api/order. I explicitly confirm this removal.",
      "expectedTool": "remove_breakpoint",
      "expectedArgs": {
        "action": "remove_xhr",
        "url": "/api/order",
        "confirm": true
      }
    },
    {
      "id": "list-breakpoints",
      "category": "initiator_breakpoint",
      "prompt": "Show the currently active code and XHR breakpoints without changing them.",
      "expectedTool": "list_breakpoints",
      "expectedArgs": {}
    },
    {
      "id": "request-initiator",
      "category": "initiator_breakpoint",
      "prompt": "Captured request reqid 42 is the interesting API call. Show which JavaScript call stack initiated it.",
      "expectedTool": "get_request_initiator",
      "expectedArgs": {"requestId": 42}
    },
    {
      "id": "inspect-paused-scopes",
      "category": "initiator_breakpoint",
      "prompt": "A breakpoint has just paused execution. Inspect the call stack and local scope variables in the top frame.",
      "expectedTool": "get_paused_info",
      "expectedArgs": {}
    },
    {
      "id": "resume-explicitly",
      "category": "initiator_breakpoint",
      "prompt": "Execution is paused and the inspection is complete. Resume it explicitly.",
      "expectedTool": "pause_or_resume",
      "expectedArgs": {"action": "resume"}
    },
    {
      "id": "step-into-call",
      "category": "initiator_breakpoint",
      "prompt": "While paused, enter the function called by the current statement and return the new source location.",
      "expectedTool": "step",
      "expectedArgs": {"direction": "into"}
    },
    {
      "id": "break-on-code-text",
      "category": "initiator_breakpoint",
      "prompt": "Set a breakpoint on the second occurrence of generateSignature( inside scripts whose URL contains app.min.js.",
      "expectedTool": "set_breakpoint_on_text",
      "expectedArgs": {
        "text": "generateSignature(",
        "urlFilter": "app.min.js",
        "occurrence": 2
      }
    },
    {
      "id": "break-on-api-runtime",
      "category": "initiator_breakpoint",
      "prompt": "我需要页面下一次发送 URL 包含 /api/order 的 XHR 或 fetch 时的运行时参数；现在先配置这个暂停点。",
      "expectedTool": "break_on_xhr",
      "expectedArgs": {"url": "/api/order"}
    },
    {
      "id": "select-iframe",
      "category": "page_frame",
      "prompt": "Switch the JavaScript and element context to frame index 4 from the frame listing.",
      "expectedTool": "select_frame",
      "expectedArgs": {"frameIdx": 4}
    },
    {
      "id": "confirmed-click",
      "category": "destructive_actions",
      "prompt": "Click the single visible element matching button#load-report in the selected frame. I explicitly authorize this click.",
      "expectedTool": "click_element",
      "expectedArgs": {"selector": "button#load-report", "confirm": true}
    },
    {
      "id": "trace-httponly-cookie",
      "category": "cookie_network",
      "prompt": "精确名为 session 的 HttpOnly Cookie 是哪个响应创建或刷新的？请追踪它的 Set-Cookie 历史。",
      "expectedTool": "list_network_requests",
      "expectedArgs": {"cookieName": "session"}
    },
    {
      "id": "clear-network-evidence",
      "category": "destructive_actions",
      "prompt": "Clear the captured network request history and body cache for this page. I explicitly confirm that the evidence can be deleted.",
      "expectedTool": "clear_network_requests",
      "expectedArgs": {"confirm": true}
    },
    {
      "id": "select-page",
      "category": "page_frame",
      "prompt": "Switch the debugging context to open page index 2.",
      "expectedTool": "select_page",
      "expectedArgs": {"pageIdx": 2}
    },
    {
      "id": "open-separate-page",
      "category": "page_frame",
      "prompt": "Open https://example.com/login in a separate browser page.",
      "expectedTool": "new_page",
      "expectedArgs": {"url": "https://example.com/login"}
    },
    {
      "id": "reload-selected-page",
      "category": "page_frame",
      "prompt": "Reload the currently selected page without clearing cookies, storage, or cache.",
      "expectedTool": "navigate_page",
      "expectedArgs": {"type": "reload"}
    },
    {
      "id": "full-page-screenshot",
      "category": "observability",
      "prompt": "Capture the full selected page as PNG and save it to the new file /tmp/page.png.",
      "expectedTool": "take_screenshot",
      "expectedArgs": {
        "fullPage": true,
        "filePath": "/tmp/page.png"
      }
    },
    {
      "id": "main-world-evaluation",
      "category": "destructive_actions",
      "prompt": "Run () => window.__APP_VERSION__ in the page main world. I explicitly authorize this JavaScript evaluation.",
      "expectedTool": "evaluate_script",
      "expectedArgs": {
        "function": "() => window.__APP_VERSION__",
        "mainWorld": true,
        "confirm": true
      }
    },
    {
      "id": "site-scoped-reset",
      "category": "destructive_actions",
      "prompt": "为了干净地重放登录流程，清理影响当前站点 frame 的 Cookie 和存储，但保留浏览器全局 HTTP cache；我明确确认这次删除。",
      "expectedTool": "clear_site_data",
      "expectedArgs": {"confirm": true}
    },
    {
      "id": "list-websockets",
      "category": "websocket",
      "prompt": "List WebSocket connections whose URL contains /realtime; do not inspect the HTTP upgrade request.",
      "expectedTool": "get_websocket_messages",
      "expectedArgs": {"urlFilter": "/realtime"}
    },
    {
      "id": "trace-cookie-deletion",
      "category": "cookie_network",
      "prompt": "Find every response that overwrote or deleted the exact Secure cookie sid. I need the oldest-first Set-Cookie flow, not outbound Cookie headers.",
      "expectedTool": "list_network_requests",
      "expectedArgs": {"cookieName": "sid"}
    },
    {
      "id": "export-cookie-headers",
      "category": "cookie_network",
      "prompt": "Cookie tracing returned reqid 73. Export its complete response headers, including repeated Set-Cookie attributes, to the new file /tmp/session-headers.json.",
      "expectedTool": "list_network_requests",
      "expectedArgs": {
        "reqid": 73,
        "outputPart": "responseHeaders",
        "outputFile": "/tmp/session-headers.json"
      }
    },
    {
      "id": "filter-api-requests",
      "category": "cookie_network",
      "prompt": "List captured POST fetch requests whose URL contains /api/login.",
      "expectedTool": "list_network_requests",
      "expectedArgs": {
        "methods": ["POST"],
        "resourceTypes": ["fetch"],
        "urlFilter": "/api/login"
      }
    },
    {
      "id": "analyze-websocket-patterns",
      "category": "websocket",
      "prompt": "Group retained received messages on WebSocket wsid 3 by payload pattern so I can compare message types.",
      "expectedTool": "get_websocket_messages",
      "expectedArgs": {"wsid": 3, "analyze": true, "direction": "received"}
    },
    {
      "id": "list-open-pages",
      "category": "page_frame",
      "prompt": "List the currently open browser pages without changing which one is selected.",
      "expectedTool": "select_page",
      "expectedArgs": {}
    },
    {
      "id": "list-frames",
      "category": "page_frame",
      "prompt": "列出当前页面的 frame 和 iframe，但不要改变当前执行上下文。",
      "expectedTool": "select_frame",
      "expectedArgs": {}
    }
  ]
}
